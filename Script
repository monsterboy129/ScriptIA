                    ⚙️ Settings

                    💾 Save Config
                    🔄 Reset

            `;

            document.body.appendChild(this.menu);
            this.setupEventListeners();
            this.loadTabContent('player');
        }

        createHUD() {
            const hud = document.createElement('div');
            hud.id = 'vl-hud';
            hud.innerHTML = `

                    ⚡ Power: ${gameState.playerStats.power}
                    🏃 Speed: ${gameState.playerStats.speed}
                    🦘 Jump: ${gameState.playerStats.jump}

