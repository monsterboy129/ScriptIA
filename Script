                }

                .vl-toggle {
                    position: relative;
                    display: inline-block;
                    width: 50px;
                    height: 24px;
                    margin-right: 10px;
                }

                .vl-toggle input {
                    opacity: 0;
                    width: 0;
                    height: 0;
                }

                .vl-toggle-slider {
                    position: absolute;
                    cursor: pointer;
                    top: 0;
                    left: 0;
                    right: 0;
                    bottom: 0;
                    background-color: #444;
                    transition: .4s;
                    border-radius: 24px;
                }

                .vl-toggle-slider:before {
                    position: absolute;
                    content: "";
                    height: 16px;
                    width: 16px;
                    left: 4px;
                    bottom: 4px;
                    background-color: white;
                    transition: .4s;
                    border-radius: 50%;
                }

                input:checked + .vl-toggle-slider {
                    background-color: #00ff88;
                }

                input:checked + .vl-toggle-slider:before {
                    transform: translateX(26px);
                }

