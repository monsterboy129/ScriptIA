-- Função para encontrar a bola
local function FindBall()
    for _, obj in pairs(game:GetService("Workspace"):GetDescendants()) do
        if obj.Name:lower():find("ball") or obj.Name:lower():find("volley") then
            if obj:IsA("BasePart") then
                return obj
            end
        end
    end
    return nil
end

-- Função para auto-serviço
local function AutoServeFunction()
    while Config.AutoServe do
        wait(0.5)
        local ball = FindBall()
        if ball then
            local distance = (HumanoidRootPart.Position - ball.Position).Magnitude
            if distance < 20 then
                -- Simular tecla de serviço (pode precisar de ajuste)
                keypress(0x45) -- Tecla E
                wait(0.1)
                keyrelease(0x45)
            end
        end
    end
end

-- Função para auto-spike
local function AutoSpikeFunction()
    while Config.AutoSpike do
        wait(0.3)
        local ball = FindBall()
        if ball then
            local distance = (HumanoidRootPart.Position - ball.Position).Magnitude
            if distance < 15 and ball.Position.Y > HumanoidRootPart.Position.Y + 2 then
                -- Simular tecla de spike (pode precisar de ajuste)
                keypress(0x51) -- Tecla Q
                wait(0.1)
                keyrelease(0x51)
            end
        end
    end
end

-- Função para auto-bloco
local function AutoBlockFunction()
    while Config.AutoBlock do
        wait(0.2)
        local ball = FindBall()
        if ball then
            local velocity = ball.Velocity
            -- Verificar se a bola está vindo em direção ao jogador
            if velocity.Magnitude > 20 then
                local directionToPlayer = (HumanoidRootPart.Position - ball.Position).Unit
                local dotProduct = velocity.Unit:Dot(directionToPlayer)
                
                if dotProduct > 0.7 then -- Bola vindo na direção do jogador
                    -- Simular tecla de bloco (pode precisar de ajuste)
                    keypress(0x52) -- Tecla R
                    wait(0.1)
                    keyrelease(0x52)
                end
            end
        end
    end
end

-- Função para ESP da bola
local function BallESPFunction()
    while Config.BallESP do
        wait(0.5)
        local ball = FindBall()
        if ball then
            -- Criar highlight se não existir
            if not ball:FindFirstChild("BallHighlight") then
                local highlight = Instance.new("Highlight")
                highlight.Name = "BallHighlight"
                highlight.FillColor = Color3.fromRGB(255, 255, 0)
                highlight.OutlineColor = Color3.fromRGB(255, 165, 0)
                highlight.Parent = ball
            end
        end
        -- Limpar highlights antigos
        for _, obj in pairs(game:GetService("Workspace"):GetDescendants()) do
            if obj.Name == "BallHighlight" and not FindBall() then
                obj:Destroy()
            end
        end
    end
end

-- Função para ESP dos jogadores
local function PlayerESPFunction()
    while Config.PlayerESP do
        wait(1)
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local character = player.Character
                if character and character:FindFirstChild("HumanoidRootPart") then
                    -- Criar billboard gui se não existir
                    if not character:FindFirstChild("PlayerESP") then
                        local billboard = Instance.new("BillboardGui")
                        billboard.Name = "PlayerESP"
                        billboard.Size = UDim2.new(0, 100, 0, 50)
                        billboard.StudsOffset = Vector3.new(0, 3, 0)
                        billboard.AlwaysOnTop = true
                        billboard.Parent = character.HumanoidRootPart
                        
                        local textLabel = Instance.new("TextLabel")
                        textLabel.Size = UDim2.new(1, 0, 1, 0)
                        textLabel.Text = player.Name
                        textLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
                        textLabel.BackgroundTransparency = 1
                        textLabel.Font = Enum.Font.GothamBold
                        textLabel.TextStrokeTransparency = 0.5
                        textLabel.Parent = billboard
                    end
                end
            end
        end
    end
end

-- Função para teleportar até a bola
local function TeleportToBallFunction()
    while Config.TeleportToBall do
        wait(0.5)
        local ball = FindBall()
        if ball and Character and HumanoidRootPart then
            -- Teleportar para perto da bola (não diretamente nela)
            local offset = Vector3.new(math.random(-5, 5), 0, math.random(-5, 5))
            HumanoidRootPart.CFrame = CFrame.new(ball.Position + offset)
        end
    end
end

-- Função principal de loop
local function MainLoop()
    while wait(0.1) do
        -- Aplicar velocidade de caminhada
        if Humanoid then
            Humanoid.WalkSpeed = Config.WalkSpeed
            Humanoid.JumpPower = Config.JumpPower
            
            -- Anti-stun (remove efeitos de stun)
            if Config.AntiStun then
                for _, v in pairs(Humanoid:GetPlayingAnimationTracks()) do
                    if v.Name:lower():find("stun") or v.Name:lower():find("hit") then
                        v:Stop()
                    end
                end
            end
            
            -- Stamina infinita (remove cansaço)
            if Config.InfiniteStamina then
                for _, v in pairs(Character:GetDescendants()) do
                    if v:IsA("NumberValue") and v.Name:lower():find("stamina") then
                        v.Value = 100
                    end
                end
            end
            
            -- No cooldown (remove cooldowns de habilidades)
            if Config.NoCooldown then
                for _, v in pairs(Character:GetDescendants()) do
                    if v:IsA("NumberValue") and (v.Name:lower():find("cooldown") or v.Name:lower():find("cd")) then
                        v.Value = 0
                    end
                end
            end
            
            -- Auto jump quando perto da bola e ela está alta
            if Config.AutoJump then
                local ball = FindBall()
                if ball then
                    local distance = (HumanoidRootPart.Position - ball.Position).Magnitude
                    if distance < 10 and ball.Position.Y > HumanoidRootPart.Position.Y + 5 then
                        Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    end
                end
            end
        end
        
        -- Verificar se funções devem ser iniciadas/paradas
        coroutine.wrap(function()
            -- Iniciar/parar funções baseado nas configurações
            if Config.AutoServe then coroutine.wrap(AutoServeFunction)() end
            if Config.AutoSpike then coroutine.wrap(AutoSpikeFunction)() end
            if Config.AutoBlock then coroutine.wrap(AutoBlockFunction)() end
            if Config.BallESP then coroutine.wrap(BallESPFunction)() end
            if Config.PlayerESP then coroutine.wrap(PlayerESPFunction)() end
            if Config.TeleportToBall then coroutine.wrap(TeleportToBallFunction)() end
        end)()
    end
end

-- Limpar ESP quando desativado
game:GetService("RunService").Heartbeat:Connect(function()
    if not Config.BallESP then
        for _, obj in pairs(game:GetService("Workspace"):GetDescendants()) do
            if obj.Name == "BallHighlight" then
                obj:Destroy()
            end
        end
    end
    
    if not Config.PlayerESP then
        for _, player in pairs(Players:GetPlayers()) do
            local character = player.Character
            if character and character:FindFirstChild("PlayerESP") then
                character.PlayerESP:Destroy()
            end
        end
    end
end)

-- Iniciar loop principal
coroutine.wrap(MainLoop)()

