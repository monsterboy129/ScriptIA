                    right: 10px;
                    background: rgba(0,0,0,0.8);
                    border: 2px solid #00ff88;
                    border-radius: 10px;
                    padding: 10px;
                    z-index: 99998;
                    color: white;
                    font-family: 'Arial', sans-serif;
                }

                .vl-hud-stats {
                    display: flex;
                    flex-direction: column;
                    margin-bottom: 10px;
                }

                .vl-hud-stats span {
                    font-size: 12px;
                    margin: 2px 0;
                }

                .vl-hud-controls {
                    display: flex;
                    gap: 5px;
                }

                .vl-hud-btn {
                    flex: 1;
                    padding: 5px 10px;
                    background: #00ff88;
                    border: none;
                    border-radius: 5px;
                    color: #000;
                    font-weight: bold;
                    cursor: pointer;
                    font-size: 11px;
                }

                .hit-marker {
                    position: absolute;
                    width: 20px;
                    height: 20px;
                    background: radial-gradient(circle, #ff0000, transparent);
                    border-radius: 50%;
                    pointer-events: none;
                    animation: pulse 0.5s ease-out;
                }

                .trajectory-line {
                    position: absolute;
                    background: linear-gradient(to right, #00ff88, transparent);
                    height: 3px;
                    pointer-events: none;
                    transform-origin: left center;
                }

                @keyframes pulse {
                    0% { transform: scale(1); opacity: 1; }
                    100% { transform: scale(2); opacity: 0; }
                }
            `);
        }

        loadTabContent(tabName) {
            const content = this.menu.querySelector('.vl-tab-content');

            switch(tabName) {
                case 'player':
                    content.innerHTML = this.getPlayerTab();
                    break;
                case 'match':
                    content.innerHTML = this.getMatchTab();
                    break;
                case 'visual':
                    content.innerHTML = this.getVisualTab();
                    break;
                case 'economy':
                    content.innerHTML = this.getEconomyTab();
                    break;
                case 'settings':
                    content.innerHTML = this.getSettingsTab();
                    break;
            }

            this.setupTabControls();
        }

